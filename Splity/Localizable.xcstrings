{
  "sourceLanguage" : "en",
  "strings" : {
    "「%@」刪除後無法復原" : {
      "comment" : "An alert message that appears when a user attempts to delete an expense, explaining that the deletion cannot be undone.",
      "isCommentAutoGenerated" : true
    },
    "/ %@" : {
      "comment" : "A label showing the ratio of the sum of custom amounts to the total amount.",
      "isCommentAutoGenerated" : true
    },
    "%@ 先付" : {
      "comment" : "A label indicating that a user has paid for an expense. The text inside the parentheses is a placeholder for the user's name.",
      "isCommentAutoGenerated" : true
    },
    "%@ 轉給 %@" : {
      "comment" : "A label describing a settlement, indicating who sent and received the funds. The first argument is the name of the sender. The second argument is the name of the receiver.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ 轉給 %2$@"
          }
        }
      }
    },
    "%lld 人・%lld 筆花費" : {
      "comment" : "A sublabel showing the number of members and expenses in a group. The first argument is the count of members in the group. The second argument is the count of expenses in the group.",
